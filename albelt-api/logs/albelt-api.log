                or lower(a1_0.adresse) like ('%'||?||'%') escape ''
            ) 
            and a1_0.created_at>=? 
            and a1_0.created_at<=? 
        order by
            a1_0.created_at desc 
        offset
            ? rows 
        fetch
            first ? rows only
