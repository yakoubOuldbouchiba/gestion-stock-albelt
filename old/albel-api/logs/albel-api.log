INSERT INTO rolls (material_type, width_mm, length_m, original_quantity, supplier_id, received_date, status, location, created_by) 
SELECT 
    material_type,
    width_mm,
    length_m,
    original_quantity,
    supplier_id,
    received_date,
    status,
    location,
    (SELECT id FROM users WHERE username = 'admin' LIMIT 1)
FROM (
    VALUES
    -- PU Materials
    ('PU', 1200, 50.0, '50kg', (SELECT id FROM suppliers WHERE name = 'Fournisseur PU Alg‚rie' LIMIT 1), '2026-03-19', 'AVAILABLE', 'Chute-1'),
    ('PU', 1200, 45.0, '45kg', (SELECT id FROM suppliers WHERE name = 'Fournisseur PU Alg‚rie' LIMIT 1), '2026-03-20', 'AVAILABLE', 'Chute-2'),
