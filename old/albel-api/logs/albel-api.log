        r1_0.surface_remaining_m2,
        r1_0.surface_remaining_percent,
        r1_0.thickness_mm,
        r1_0.updated_at,
        r1_0.waste_type,
        r1_0.width_initial_mm 
    from
        rolls r1_0 
    join
        suppliers s1_0 
            on s1_0.id=r1_0.supplier_id 
    where
        r1_0.id=?
